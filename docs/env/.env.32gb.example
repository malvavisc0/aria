# ─────────────────────────────────────────────────────────────────────────────
# Aria .env — 32 GB VRAM + 8 GB INT8 model (e.g. RTX 4090, RTX 5090, A5000)
#
# VRAM budget:
#   Model weights (INT8): ~8 GB
#   CUDA/runtime overhead: ~2 GB
#   KV cache (fp8):       ~20 GB → 256K context with fp8 compression
#   Total:                ~30 GB of 32 GB
#
# This config uses a larger INT8 model (OmniCoder-9B) with a 256K context
# window, Qwen3 reasoning, and vision support enabled.
# ─────────────────────────────────────────────────────────────────────────────

DEBUG = true  # Set to false to reduce logging verbosity

# Server basics
SERVER_HOST = 0.0.0.0
SERVER_PORT = 9876
CHAINLIT_AUTH_SECRET =          # auto-generated on first run

# Agent loop safety and per-request caps
MAX_ITERATIONS = 30
TOKEN_LIMIT_RATIO = 0.30  # 30% of CHAT_CONTEXT_SIZE for memory; leaves ~70% for system prompt + tools + response

# Chat service and model — 8 GB INT8 model for 32 GB VRAM
CHAT_OPENAI_API = http://localhost:9090/v1
CHAT_MODEL = OmniCoder-9B
CHAT_MODEL_PATH = malvavisc0/omnicoder-9b-gptq-int8
CHAT_CONTEXT_SIZE = 262144
CHAT_TEMPLATE_FILE =       # Leave empty to use the model's built-in chat template

# Embeddings (CPU-only, ~600 MB RAM — no VRAM impact)
EMBEDDINGS_MODEL = Granite-Embedding-311M-Multilingual-R2
EMBED_MODEL_PATH = ibm-granite/granite-embedding-311m-multilingual-r2
EMBEDDINGS_CONTEXT_SIZE = 8192

# vLLM engine — tuned for 32 GB VRAM + INT8 model
ARIA_VLLM_GPU_MEMORY_UTILIZATION =      # auto-calculated at launch
ARIA_VLLM_QUANT = gptq_marlin
ARIA_VLLM_TP_SIZE = 1
ARIA_VLLM_DTYPE = auto
ARIA_VLLM_KV_CACHE_DTYPE = fp8
ARIA_VLLM_API_KEY = sk-aria
ARIA_VLLM_TOOL_CALL_PARSER = qwen3_coder
ARIA_VLLM_REASONING_PARSER = qwen3
ARIA_VLLM_CHAT_TEMPLATE_KWARGS = {"enable_thinking": true}
ARIA_VLLM_VISION_ENABLED = true
ARIA_VLLM_DATA_PARALLEL_SIZE = 1
ARIA_VLLM_EXPERT_PARALLEL =
ARIA_VLLM_MM_ENCODER_TP_MODE =
ARIA_VLLM_MM_PROCESSOR_CACHE_TYPE =
ARIA_VLLM_PREFIX_CACHING = true

# KV cache offloading
ARIA_VLLM_KV_OFFLOAD_MODE = off
# ARIA_VLLM_KV_OFFLOADING_SIZE_GB =    # Auto-calculated when unset
ARIA_VLLM_KV_OFFLOADING_BACKEND = native  # native | lmcache

# Max tokens for generation (including system prompt, tools, and response)
ARIA_MAX_TOKENS = 16384

# LLM sampling parameters
ARIA_VLLM_TEMPERATURE = 0.1
ARIA_VLLM_TOP_P = 0.85
ARIA_VLLM_TOP_K = 10
ARIA_VLLM_MIN_P = 0.05
ARIA_VLLM_PRESENCE_PENALTY = 0.0
ARIA_VLLM_REPETITION_PENALTY = 1.05
ARIA_VLLM_SEED = 42

# Paths and persistence
ARIA_DB_FILENAME = aria.db
CHROMADB_PERSISTENT_PATH = chromadb
HF_TOKEN =

# Lightpanda browser (optional — browser tools disabled if not installed)
LIGHTPANDA_VERSION = nightly
LIGHTPANDA_PORT = 9222

# CUDA settings
CUDA_MODULE_LOADING = LAZY

# Optional tool endpoints
BYPARR_API_URL = http://byparr:8191
SEARXNG_URL = http://searxng:8080