# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.debian — Lightweight Aria image (no GPU / vLLM)
#
# For users who connect to a remote LLM endpoint or run CPU-only.
# Based on Debian 13 (Trixie) — much smaller than the vLLM images.
#
# Build:
#   docker build -f Dockerfile.debian -t aria-lite .
#
# Run:
#   docker run -p 9876:9876 -v ./data:/app/data ghcr.io/malvavisc0/aria-lite:latest
# ─────────────────────────────────────────────────────────────────────────────

FROM debian:trixie-slim

LABEL org.opencontainers.image.source="https://github.com/malvavisc0/aria"
LABEL org.opencontainers.image.description="Aria — lightweight image (no GPU). Use with remote LLM endpoints."
LABEL org.opencontainers.image.licenses="MIT"

# ── Install Python and minimal system dependencies ──────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    curl \
    tini && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ── Install Aria ──────────────────────────────────────────────────────────────
RUN pip install --no-cache-dir --break-system-packages aria-ai

# ── Create data directory for persistent storage ──────────────────────────────
RUN mkdir -p /app/data
WORKDIR /app

# ── Expose Chainlit web UI port ───────────────────────────────────────────────
EXPOSE 9876

# ── Entrypoint ────────────────────────────────────────────────────────────────
ENTRYPOINT ["tini", "--", "aria", "server", "run"]