# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Keep the `.files/` directory structure in the repo, but do not track its contents.
#
# Notes:
# - Git does not track empty directories, so we keep directories by committing
#   `.gitkeep` files.
# - Everything else under `.files/` is ignored.
.files/**
!.files/**/.gitkeep

# Runtime data lives under ~/.aria (not in the repo).
# Legacy data/ rules kept for backward compatibility during transition.
data/**
!data/.gitkeep

# Build directories
build/
!build/.gitkeep

# Virtual environments
.venv

