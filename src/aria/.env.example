DEBUG = true  # Set to false to reduce logging verbosity

# Server basics
SERVER_HOST =
SERVER_PORT = 9876
CHAINLIT_AUTH_SECRET =

# Agent loop safety and per-request caps
MAX_ITERATIONS = 50
TOKEN_LIMIT = 49152  # must be ≤ 75% of CHAT_CONTEXT_SIZE

# Chat service and model
# Default: Q4_0 (~2.5 GB VRAM) with 64k context — fits 8 GB GPU
# For higher quality (10+ GB GPU): switch to Q8_0 and increase CHAT_CONTEXT_SIZE
CHAT_OPENAI_API = http://localhost:9090/v1
CHAT_MODEL_REPO = Menlo/Lucy-128k-gguf
CHAT_MODEL = lucy_128k-Q4_0.gguf
CHAT_MODEL_TYPE = Q4_0
CHAT_CONTEXT_SIZE = 65536
CHAT_TEMPLATE_FILE = chat.template

# Vision-language service and model
# Default: Q4_0 (~0.8 GB VRAM) — small model, minimal impact
# If VRAM pressure: switch VISION_MODEL_TYPE to Q4_K_M (~0.5 GB)
VL_OPENAI_API = http://localhost:9091/v1
VL_MODEL_REPO = unsloth/Qwen3.5-0.8B-GGUF
VL_MODEL = Qwen3.5-0.8B-Q4_0.gguf
VL_MMPROJ_MODEL = mmproj-F16.gguf
VISION_MODEL_TYPE = Q4_0
VL_CONTEXT_SIZE = 16384  # 16k; image/PDF tasks rarely exceed 8k tokens

# Embeddings service and model
# Default: Q4_K_M (~1.0 GB VRAM) for 8 GB GPU compatibility
# For higher quality (10+ GB GPU): switch to Q8_0 (lnovey/Qodo-Embed-1-1.5B-Q8_0-GGUF) and increase EMBEDDINGS_CONTEXT_SIZE
EMBEDDINGS_API_URL = http://localhost:9092/v1
EMBEDDINGS_MODEL_REPO = fuckoff11/Qodo-Embed-1-1.5B-Q4_K_M-GGUF
EMBEDDINGS_MODEL = qodo-embed-1-1.5b-q4_k_m.gguf
EMBEDDINGS_MODEL_TYPE = Q4_K_M
EMBEDDINGS_CONTEXT_SIZE = 16384  # must not exceed model's max input tokens

# Paths and persistence
DATA_FOLDER = data
ARIA_DB_FILENAME = aria.db
LOCAL_STORAGE_PATH = storage
CHROMADB_PERSISTENT_PATH = chromadb
LLAMA_CPP_BIN_DIR = bin/llamacpp
LLAMA_CPP_VERSION = latest
HUGGINGFACE_TOKEN =
GGUF_MODELS_DIR = models

# Lightpanda browser (optional — browser tools disabled if not installed)
LIGHTPANDA_BIN_DIR = bin/lightpanda
LIGHTPANDA_VERSION = nightly
LIGHTPANDA_PORT = 9222

# KV cache offloading: true = offload KV cache to system RAM (saves VRAM, recommended for 8 GB GPU)
# false = keep KV cache on GPU (faster inference, requires 10+ GB VRAM)
KV_CACHE_OFFLOAD = true

# Force context: bypass the run-model safety cap so CHAT_CONTEXT_SIZE is honored exactly
# Set to true when you've profiled your model+hardware and know the context fits
# Set to false (default) to let the script auto-cap based on VRAM
FORCE_CONTEXT = false

BYPARR_API_URL=
SEARXNG_URL=
