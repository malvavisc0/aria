DEBUG = true  # Set to false to reduce logging verbosity

# Server basics
SERVER_HOST = 0.0.0.0
SERVER_PORT = 9876
CHAINLIT_AUTH_SECRET = 

# Agent loop safety and per-request caps
MAX_ITERATIONS = 60
TOKEN_LIMIT = 65536  # Memory budget for conversation history; must be < CHAT_CONTEXT_SIZE

# Chat service and model
CHAT_OPENAI_API = http://localhost:9090/v1
CHAT_MODEL_REPO = unsloth/Jan-nano-GGUF
CHAT_MODEL = Jan-nano-Q8_0.gguf
CHAT_MODEL_TYPE = Q8_0
CHAT_CONTEXT_SIZE = 262144
CHAT_TEMPLATE_FILE = chat.template

# Vision-language service and model
VL_OPENAI_API = http://localhost:9091/v1
VL_MODEL_REPO = runanywhere/LFM2-VL-450M-GGUF
VL_MODEL = LFM2-VL-450M-Q8_0.gguf
VL_MMPROJ_MODEL = mmproj-LFM2-VL-450M-Q8_0.gguf
VISION_MODEL_TYPE = Q8_0  # Switch to Q4_K_M if VRAM pressure
VL_CONTEXT_SIZE = 8192

# Embeddings service and model
EMBEDDINGS_API_URL = http://localhost:9092/v1
EMBEDDINGS_MODEL_REPO = Qwen/Qwen3-Embedding-0.6B-GGUF
EMBEDDINGS_MODEL = Qwen3-Embedding-0.6B-Q8_0.gguf
EMBEDDINGS_MODEL_TYPE = Q8_0
EMBEDDINGS_CONTEXT_SIZE = 16384  # Balanced throughput vs length; 32768 if needed

# Paths and persistence
DATA_FOLDER = data
ARIA_DB_FILENAME = aria.db
LOCAL_STORAGE_PATH = storage
CHROMADB_PERSISTENT_PATH = chromadb
LLAMA_CPP_BIN_DIR = bin/llamacpp
LLAMA_CPP_VERSION = latest
HUGGINGFACE_TOKEN =
GGUF_MODELS_DIR = models

# KV cache location (IMPORTANT for performance):
#   false = KV cache stays on GPU (FAST — recommended if you have enough VRAM)
#   true  = KV cache offloaded to system RAM (SLOW — uses PCIe bus, 10-50x slower)
# Default: true (safe for low-VRAM GPUs, but set to false if VRAM allows)
KV_CACHE_OFFLOAD = false

# Langfuse observability (optional — instrumentation disabled if not set)
LANGFUSE_SECRET_KEY =
LANGFUSE_PUBLIC_KEY =
LANGFUSE_BASE_URL =

# Lightpanda browser (optional — browser tools disabled if not installed)
LIGHTPANDA_BIN_DIR = bin/lightpanda
LIGHTPANDA_VERSION = nightly
LIGHTPANDA_PORT = 9222
