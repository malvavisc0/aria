DEBUG = true  # Set to false to reduce logging verbosity

# Server basics
SERVER_HOST = 0.0.0.0
SERVER_PORT = 9876
CHAINLIT_AUTH_SECRET =

# Agent loop safety and per-request caps
MAX_ITERATIONS = 30
TOKEN_LIMIT_RATIO = 0.25  # 25% of CHAT_CONTEXT_SIZE for memory; leaves ~75% for system prompt + tools + response

# Chat service and model
# Recommended for 8 GB VRAM: any 8B INT4/GPTQ model (weights ~4 GB, KV cache ~3 GB at fp8 + 32k ctx)
CHAT_OPENAI_API = http://localhost:9090/v1
CHAT_MODEL = RenCoder-Ministral-3-8B-Instruct
CHAT_MODEL_PATH = malvavisc0/rencoder-ministral-3-8b-instruct-gptq-int4
CHAT_CONTEXT_SIZE = 32768  # Safe for 8 GB VRAM + fp8 KV; try 49152 if vLLM accepts it at startup

CHAT_TEMPLATE_FILE =       # Leave empty to use the model's built-in chat template

# Embeddings model (loaded in-process via HuggingFace — no server needed)
# 311M model ≈ 600 MB RAM — well within 16 GB budget; 1.5B models are too heavy for in-process use
EMBEDDINGS_MODEL = granite-embedding-311m-multilingual-r2
EMBED_MODEL_PATH = ibm-granite/granite-embedding-311m-multilingual-r2
EMBEDDINGS_CONTEXT_SIZE = 8192  # token_flush_size: tokens moved to long-term vector memory per overflow cycle

# Paths and persistence
# Runtime data lives under ~/.aria by default.
# Set ARIA_HOME to override the root (e.g. for containerised deployments).
#ARIA_HOME = ~/.aria
ARIA_DB_FILENAME = aria.db
CHROMADB_PERSISTENT_PATH = chromadb
HF_TOKEN =

# Lightpanda browser (optional — browser tools disabled if not installed)
# Binaries are installed to ~/.aria/bin by default.
LIGHTPANDA_VERSION = nightly
LIGHTPANDA_PORT = 9222

# vLLM engine configuration
#
# ARIA_VLLM_REMOTE:
#   Connect to a remote OpenAI-compatible vLLM endpoint instead of
#   managing a local vLLM process.  When true, CHAT_OPENAI_API is
#   used as the endpoint URL and ARIA_VLLM_API_KEY as the auth key.
#   Local GPU, model download, and vLLM install checks are skipped.
#   Example:
#     ARIA_VLLM_REMOTE=true
#     CHAT_OPENAI_API=http://gpu-server:9090/v1
#     ARIA_VLLM_API_KEY=sk-my-remote-key
ARIA_VLLM_REMOTE =
#
# Tuned for 8 GB VRAM (RTX 2070 Super / 3060 / 4060 / 4060 Ti) with a single 8B GPTQ-INT4 chat model
#
# ARIA_VLLM_QUANT:              gptq_marlin (INT4, best for ≤8 GB), awq, or blank for none
# ARIA_VLLM_TP_SIZE:            1 — single GPU (no NVLink on mobile)
# ARIA_VLLM_DTYPE:              auto
# ARIA_VLLM_KV_CACHE_DTYPE:     fp8 — essential on 8 GB; halves KV cache VRAM; FlashInfer auto-enabled
# ARIA_VLLM_API_KEY:            shared secret for vLLM auth; must match on server and all clients
# ARIA_VLLM_TOOL_CALL_PARSER:   match your model family (granite4, qwen3_coder, hermes, llama3_json, etc.)
#   hermes is correct for Qwen-family models; granite4 for Granite models
# ARIA_VLLM_REASONING_PARSER:   only for thinking/CoT models (qwen3, deepseek_r1); leave blank for Granite
#   when set, you MUST also enable thinking in CHAT_TEMPLATE_KWARGS (see below)
# ARIA_VLLM_CHAT_TEMPLATE_KWARGS: JSON string passed as --default-chat-template-kwargs to vLLM
#   e.g. '{"enable_thinking": true}' for Qwen3/Qwen3.5 thinking mode; leave blank to disable
#   IMPORTANT: when using reasoning_parser, you MUST also enable thinking in CHAT_TEMPLATE_KWARGS (see below)
# max_model_len is derived from CHAT_CONTEXT_SIZE above
#
# ARIA_VLLM_VISION_ENABLED:
#   Enable multi-modal (vision/image) support in vLLM.
#   When disabled (default), skips multi-modal warmup to save ~6s startup.
#   Set to "true" if your model supports vision (e.g., LLaVA, Qwen-VL).
ARIA_VLLM_VISION_ENABLED =
#
# ARIA_VLLM_DATA_PARALLEL_SIZE:
#   Number of data-parallel replicas (e.g. 8 for 8-GPU data parallelism).
#   Default: 1 (no data parallelism). Only useful for multi-GPU setups.
ARIA_VLLM_DATA_PARALLEL_SIZE = 1
#
# ARIA_VLLM_EXPERT_PARALLEL:
#   Enable expert parallelism for Mixture-of-Experts (MoE) models.
#   Set to "true" for models like Qwen3.5-397B-A17B. Default: disabled.
ARIA_VLLM_EXPERT_PARALLEL =
#
# ARIA_VLLM_MM_ENCODER_TP_MODE:
#   Multi-modal encoder tensor parallelism mode (e.g. "data").
#   Used with large vision-language models. Leave blank to disable.
ARIA_VLLM_MM_ENCODER_TP_MODE =
#
# ARIA_VLLM_MM_PROCESSOR_CACHE_TYPE:
#   Multi-modal processor cache type (e.g. "shm" for shared memory).
#   Used with large vision-language models. Leave blank to disable.
ARIA_VLLM_MM_PROCESSOR_CACHE_TYPE =
#
# ARIA_VLLM_PREFIX_CACHING:
#   Enable automatic prefix caching for faster inference with shared
#   prompt prefixes. Set to "true" to enable. Default: disabled.
ARIA_VLLM_PREFIX_CACHING =
#
# ARIA_VLLM_GPU_MEMORY_UTILIZATION:
#   Leave UNSET to auto-calculate at launch based on detected VRAM, model
#   size, and a 10% headroom.  Example auto-calculated values:
#     8 GB GPU  → ~0.83  (leaves ~1.4 GB headroom)
#    12 GB GPU  → ~0.86  (leaves ~1.7 GB headroom)
#    24 GB GPU  → ~0.87  (leaves ~3.1 GB headroom)
#   Set a float (e.g. 0.85) to override the auto-calculation.
ARIA_VLLM_GPU_MEMORY_UTILIZATION =
#
# ARIA_MAX_TOKENS:
#   Maximum tokens the LLM can generate per response (thinking + response
#   combined).  The agent is told this value so it can self-regulate.
#   Default: 8192.  Bump to 16384 if thinking blocks get truncated.
ARIA_MAX_TOKENS = 16384

# LLM sampling parameters (tune for your model and use case)
ARIA_VLLM_TEMPERATURE = 0.1
ARIA_VLLM_TOP_P = 0.85
ARIA_VLLM_TOP_K = 10
ARIA_VLLM_MIN_P = 0.05
ARIA_VLLM_PRESENCE_PENALTY = 0.0
ARIA_VLLM_REPETITION_PENALTY = 1.05
ARIA_VLLM_SEED = 42
ARIA_VLLM_QUANT = gptq_marlin
ARIA_VLLM_TP_SIZE = 1
ARIA_VLLM_DTYPE = auto
ARIA_VLLM_KV_CACHE_DTYPE = auto
# Extends GPU KV cache for more CONCURRENT requests.
# Does NOT increase max_model_len (per-request context).  vLLM requires
# the GPU KV cache to hold at least one request at max_model_len.
# If context exceeds GPU capacity, it will be auto-clamped at launch.
# Use fp8 KV cache (above) to double the context that fits in GPU.
ARIA_VLLM_KV_OFFLOAD_MODE = off
# ARIA_VLLM_KV_OFFLOADING_SIZE_GB =      # Auto-calculated when unset
ARIA_VLLM_KV_OFFLOADING_BACKEND = native  # native | lmcache
ARIA_VLLM_API_KEY = sk-aria
ARIA_VLLM_TOOL_CALL_PARSER = qwen3_coder
ARIA_VLLM_REASONING_PARSER = qwen3
ARIA_VLLM_CHAT_TEMPLATE_KWARGS = {"enable_thinking": false}

# Tool output compression (controls scratchpad growth during long turns)
# Thresholds are computed as fractions of CHAT_CONTEXT_SIZE so they scale
# with context window size (32K, 131K, 262K, etc.).
#
# Ratio-based (default — recommended):
# ARIA_COMPRESS_MIN_RATIO=0.005              # 0.5% — below this: no compression
# ARIA_COMPRESS_MAX_RATIO=0.025              # 2.5% — above this: aggressive compression
# ARIA_COMPRESS_HEAD_RATIO=0.005             # 0.5% — head to keep (medium)
# ARIA_COMPRESS_TAIL_RATIO=0.002             # 0.2% — tail to keep (medium)
# ARIA_COMPRESS_AGGRESSIVE_HEAD_RATIO=0.002  # 0.2% — head to keep (aggressive)
# ARIA_COMPRESS_AGGRESSIVE_TAIL_RATIO=0.001  # 0.1% — tail to keep (aggressive)
#
# Absolute overrides (take precedence over ratios):
# ARIA_COMPRESS_MIN_CHARS=2000     # Force fixed min regardless of context size
# ARIA_COMPRESS_MAX_CHARS=8000     # Force fixed max regardless of context size
# ARIA_COMPRESS_HEAD_CHARS=1500    # Force fixed head
# ARIA_COMPRESS_TAIL_CHARS=800     # Force fixed tail
# ARIA_COMPRESS_AGGRESSIVE_HEAD=600  # Force fixed aggressive head
# ARIA_COMPRESS_AGGRESSIVE_TAIL=400  # Force fixed aggressive tail
#
# ARIA_SCRATCHPAD_PRESSURE_THRESHOLD=0.40  # Warn agent when scratchpad > 40% of context

BYPARR_API_URL = http://byparr:8191
SEARXNG_URL = http://searxng:8080

# CUDA settings
CUDA_MODULE_LOADING = LAZY

# Langfuse observability (optional — leave blank to disable)
LANGFUSE_SECRET_KEY =
LANGFUSE_PUBLIC_KEY =
LANGFUSE_BASE_URL = https://cloud.langfuse.com
